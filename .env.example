# Keep live trading disabled until you have reviewed and tested a broker adapter.
TRADING_MODE=paper

# Optional: comma-separated RSS feeds for the news crawler.
NEWS_RSS_FEEDS=https://finance.yahoo.com/news/rssindex,https://www.marketwatch.com/rss/topstories

# Optional risk controls.
MAX_ORDER_NOTIONAL=10000
DEFAULT_CASH=100000

# Optional LLM assistant. If not set, StockQuan uses local multi-theory analysis.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
